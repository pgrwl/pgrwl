{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "receive",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "daemon",
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "PGRWL_MAIN_DIRECTORY": "${workspaceFolder}/wals",
        "PGRWL_BACKUP_CRON": "* * * * *"
      }
    },
    {
      "name": "backup-cmd",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "backup"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "PGRWL_MAIN_DIRECTORY": "${workspaceFolder}/wals"
      }
    },
    {
      "name": "restore-cmd",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "restore",
        "--dest",
        "restore_test"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "PGRWL_MAIN_DIRECTORY": "${workspaceFolder}/wals"
      }
    },
    {
      "name": "ui",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl-ui/main.go",
      "buildFlags": "-tags=debug",
      "env": {
        "PGRWL_UI_CONFIG_PATH": "${workspaceFolder}/hack/configs/ui/pgrwl-ui.yml"
      }
    }
  ]
}
